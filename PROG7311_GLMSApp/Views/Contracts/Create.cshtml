@model PROG7311_GLMSApp.Models.Contract

@{
    ViewData["Title"] = "Create";
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible">
     @TempData["Error"]
     <button class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>  
}


<h1>Create New Contract</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="StartDate"  class="control-label"></label>
                <input asp-for="StartDate" type="date" class="form-control" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>
            <br />
            <div class="form-group">
                <label asp-for="EndDate" class="control-label"></label>
                <input asp-for="EndDate" type="date" class="form-control" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>
            <br />
            
            <div class="form-group">
                <label asp-for="ServiceLevel" class="control-label"></label>
                <select asp-for="ServiceLevel" class="form-control" >
                <option class="dropdown-item disabled">--- Select Service Level ---</option>
                    <option value="gold" data-bs-toggle="tooltip" title="24/7 Support; Priority Handling; 1 Hour Response Time">Gold Level</option>
                    <option value="silver" data-bs-toggle="tooltip" title="12/5 Support; Standard Handling; 4 Hour Response Time">Silver Level</option>
                <option value="bronze" data-bs-toggle="tooltip" title="8/5 Support; Basic Handling; 8 Hour Response Time">Bronze Level</option>
                </select>
                <span asp-validation-for="ServiceLevel" class="text-danger"></span>
            </div>
            <br />
            <div class="form-group">
                <label asp-for="ClientId" class="control-label">Client</label>
                <select asp-for="ClientId" class="form-control" asp-items="ViewBag.ClientId"></select>
                <span asp-validation-for="ClientId" class="text-danger"></span>
            </div>
            <br />
            <div class="mb-3">
                <label name="file" class="form-label">Service Level Agreement</label>
                <input type="file" name="file" class="form-control" accept=".pdf" />
                <span asp-validation-for="FilePath" class="text-danger"></span>
            </div>

            <div>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                <button type="submit" value="Create" class="btn btn-primary">Create</button>
            </div>
        </form>
    </div>
</div>



@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
