@model PROG7311_GLMSApp.Models.Contract

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit Contract</h1>


<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ContractId" />
            <div class="form-group">
                <label asp-for="StartDate" class="control-label"></label>
                <input asp-for="StartDate" class="form-control" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="EndDate" class="control-label"></label>
                <input asp-for="EndDate" class="form-control" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Status" class="control-label"></label>
                <select name="status" class="form-select" style="width: 250px; ">
                    <option value="">Select Status</option>
                    <option value="Active">Active</option>
                    <option value="OnHold">On Hold</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ServiceLevel" class="control-label"></label>
                <select asp-for="ServiceLevel" class="form-control">
                    <option class="dropdown-item disabled">--- Select Service Level ---</option>
                    <option value="gold" data-bs-toggle="tooltip" title="24/7 Support; Priority Handling; 1 Hour Response Time">Gold Level</option>
                    <option value="silver" data-bs-toggle="tooltip" title="12/5 Support; Standard Handling; 4 Hour Response Time">Silver Level</option>
                    <option value="bronze" data-bs-toggle="tooltip" title="8/5 Support; Basic Handling; 8 Hour Response Time">Bronze Level</option>
                </select>
                <span asp-validation-for="ServiceLevel" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ClientId" class="control-label"></label>
                <select asp-for="ClientId" class="form-control" asp-items="ViewBag.ClientId"></select>
                <span asp-validation-for="ClientId" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index" class="btn btn-dark">Back to Dashboard</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
